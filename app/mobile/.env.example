# The base URL for the backend API
# For local development with a physical device, use your machine's IP (e.g., http://192.168.1.5:3000)
# For Android Emulator, use http://10.0.2.2:3000
# For iOS Simulator, use http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Optional: human-readable environment name shown in the Health Screen badge and footer.
# Accepted values (examples): dev | staging | prod
# If omitted, the app infers the label from EXPO_PUBLIC_API_URL
# (URLs containing "staging" → staging, "prod" → prod, otherwise → dev).
EXPO_PUBLIC_ENV_NAME=dev

# Other configuration placeholders
EXPO_PUBLIC_NETWORK=testnet

# WalletConnect v2 project id from https://dashboard.walletconnect.com
# Required for wallet pairing on mobile.
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional CAIP-2 override for Stellar wallets.
# Defaults to stellar:testnet when EXPO_PUBLIC_NETWORK=testnet and stellar:mainnet otherwise.
EXPO_PUBLIC_WALLETCONNECT_STELLAR_CHAIN_ID=stellar:testnet
